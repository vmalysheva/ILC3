```{r}
# code written by Mikhail Spivakov

library(DESeq2)
dds = readRDS("dds_2025.rds")
metadata = read.table("metadata.txt", header=T, stringsAsFactors = T)
```



```{r}

ddsWt = dds[, which(metadata$CRISPR=="No")]
design(ddsWt) <- ~1+Type+Stim
